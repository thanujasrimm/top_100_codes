import java.util.Scanner;
public class num{
    public static void main(String [] args){
        Scanner sc = new Scanner(System.in);
        System.out.print("enter the digit");
        int digit = sc.nextInt();
        int rev =0;
        while(digit>0){
         int rem =digit%10;
         rev = rev*10 + (rem);
         digit = digit/10;
        }
             System.out.print("reverse of the digit"+ rev);
        sc.close();
    }}
