import java.util.Scanner;
public class Sumofnumbers{
    public static void main(String [] args){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int sum = 0;
        for(int i=1;i<=n;i++){
             if(n>0){
              sum += i;
             }
              }
              System.out.print("Sum of first" + n +  "natural numbers:"+ sum);
              sc.close();
    }
}
